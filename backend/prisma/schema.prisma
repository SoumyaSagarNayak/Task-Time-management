// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User - Team members with Clerk authentication
model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique @map("clerk_id")
  email     String
  firstName String?  @map("first_name")
  lastName  String?  @map("last_name")
  avatarUrl String?  @map("avatar_url")
  department String?
  isActive  Boolean  @default(true) @map("is_active")
  role      UserRole @default(MEMBER)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  assignedTasks       Task[]                @relation("AssignedTasks")
  timeEntries         TimeEntry[]
  comments            Comment[]
  activityLogs        ActivityLog[]
  notifications       Notification[]        @relation("UserNotifications")
  actedNotifications  Notification[]        @relation("ActorNotifications")

  @@index([clerkId])
  @@map("users")
}

// Task - Work items
model Task {
  id             String       @id @default(cuid())
  title          String
  description    String?      @db.Text
  status         TaskStatus   @default(TODO)
  priority       TaskPriority @default(MEDIUM)
  boardOrder     Float        @default(0) @map("board_order")
  estimatedHours Float?       @map("estimated_hours")
  dueDate                DateTime? @map("due_date")
  dueDateReminderSent    Boolean   @default(false) @map("due_date_reminder_sent")
  assigneeId             String?   @map("assignee_id")
  isActive       Boolean      @default(true) @map("is_active")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  // Relations
  assignee     User?        @relation("AssignedTasks", fields: [assigneeId], references: [id])
  timeEntries  TimeEntry[]  @relation("TimeEntryTasks")
  tags         Tag[]        @relation("TaskTags")
  comments     Comment[]
  blockedBy    Task[]       @relation("TaskDependencies")
  blocks       Task[]       @relation("TaskDependencies")

  @@index([status])
  @@index([boardOrder])
  @@index([createdAt])
  @@index([dueDate, dueDateReminderSent])
  @@map("tasks")
}

// Tag - Categorization for tasks
model Tag {
  id             String   @id @default(cuid())
  name           String   @unique
  color          String   @default("#3B82F6") // Default blue-500
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  // Relations
  tasks        Task[]       @relation("TaskTags")

  @@map("tags")
}

// Comment - Discussion on tasks
model Comment {
  id        String   @id @default(cuid())
  body      String   @db.Text
  taskId    String   @map("task_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([userId])
  @@map("comments")
}

// TimeEntry - Manual time logging
model TimeEntry {
  id             String   @id @default(cuid())
  userId         String   @map("user_id")
  startTime      DateTime @map("start_time")
  endTime        DateTime @map("end_time")
  hours          Float
  description    String?  @db.Text
  isBillable     Boolean  @default(false) @map("is_billable")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  // Relations
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks        Task[]       @relation("TimeEntryTasks")

  @@index([userId])
  @@index([startTime])
  @@map("time_entries")
}

// Enums
enum UserRole {
  ADMIN
  MEMBER
}

enum TaskStatus {
  OPEN
  TODO
  IN_PROGRESS
  IN_REVIEW
  DONE
  CLOSED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

// Notifications
model Notification {
  id          String   @id @default(cuid())
  recipientId String   @map("recipient_id")
  actorId     String?  @map("actor_id")
  type        String   @db.VarChar(50)   // 'task_assigned', 'mention', 'task_updated'
  entityType  String   @map("entity_type") @db.VarChar(50) // 'task', 'comment'
  entityId    String   @map("entity_id")
  payload     Json     @default("{}")
  isRead      Boolean  @default(false) @map("is_read")
  readAt      DateTime? @map("read_at")
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  recipient   User     @relation("UserNotifications", fields: [recipientId], references: [id], onDelete: Cascade)
  actor       User?    @relation("ActorNotifications", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([recipientId, isRead, createdAt(sort: Desc)])
  @@map("notifications")
}

// Activity logs for auditing
model ActivityLog {
  id             String         @id @default(cuid())
  userId         String         @map("user_id")
  action         ActivityAction
  entityType     String         @map("entity_type")
  entityId       String?        @map("entity_id")
  metadata       Json?          @default("{}")
  createdAt      DateTime       @default(now()) @map("created_at")

  // Relations
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([userId, createdAt])
  @@map("activity_logs")
}

enum ActivityAction {
  USER_CREATED
  USER_UPDATED
  USER_DELETED
  TASK_CREATED
  TASK_UPDATED
  TASK_DELETED
  TIME_LOGGED
  COMMENT_ADDED
  STATUS_CHANGED
  TIME_ENTRY_CREATED
  TIME_ENTRY_UPDATED
  TIME_ENTRY_DELETED
  TIME_ENTRY_BULK_DELETED
  TASK_REMINDER_SENT
  COMMENT_DELETED
}
